# Прокси к amoCRM — защита секретов.
Options -Indexes

# Пробросить заголовок Authorization в PHP (на части хостингов он теряется).
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>
<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# Запретить чтение config.php через веб (токен amoCRM). Синтаксис для Apache 2.2 и 2.4.
<FilesMatch "config\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
